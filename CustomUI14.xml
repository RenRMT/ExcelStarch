<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui">
	<ribbon >
		<tabs >
			<tab 
				id="Tab1"
				label="COMPANY Chart Styles">
				<group 
					id="ColumnGroup"
					label="Column">
					<button 
						id="Column"
						image="i_chart_vbar"
						label="Column Chart"
						size="large"
						supertip="Style a chart following the COMPANY standards"
						onAction="Column_onAction"/>
					<button 
						id="StackedColumn"
						image="i_chart_stacked_vbar"
						label="Stacked Column"
						size="large"
						supertip="Style a chart following the COMPANY standards"
						onAction="StackedColumn_onAction"/>
				</group >
				<group 
					id="LineGroup"
					label="Line">
					<button 
						id="LineChart"
						image="i_chart_line"
						label="Line Chart"
						size="large"
						supertip="Style a chart following the COMPANY standards"
						onAction="LineChart_onAction"/>
				</group >
				<group 
					id="BarGroup"
					label="Bar">
					<button 
						id="Bar"
						image="i_chart_hbar"
						label="Bar Chart"
						size="large"
						supertip="Style a chart following the COMPANY standards"
						onAction="Bar_onAction"/>
					<button
						id="Lollipop"
						image="i_chart_lollipop"
						label="Lollipop Chart"
						size="large"
						supertip="Style a lollipop chart following the COMPANY standards"
						onAction="Lollipop_onAction"/>
					<button 
						id="StackedBar"
						image="i_chart_stacked_hbar"
						label="Stacked Bar"
						size="large"
						supertip="Style a chart following the COMPANY standards"
						onAction="StackedBar_onAction"/>
				</group >
				<group
					id="OtherGraphs"
					label="Other Graphs">
					<button
						id="Pie"
						image="i_chart_pie"
						label="Pie Chart"
						size="large"
						supertip="Style a chart following the COMPANY standards"
						onAction="Pie_onAction"/>
					<button
						id="Area"
						image="i_menu_none"
						label="Stacked Area Chart"
						size="large"
						supertip="Style a chart following the COMPANY standards"
						onAction="Area_onAction"/>
				</group >
				<group
					id="FillColors"
					label="Fill Colors">
					<button 
						id="OceanFill"
						image="i_fill_ocean"
						size="normal"
						supertip="Ocean fill color"
						onAction="Format_onAction" 
						tag="Fill:DATA1"/>
					<button 
						id="CoralFill"
						image="i_fill_coral"
						size="normal"
						supertip="Coral fill color"
						onAction="Format_onAction"
						tag="Fill:DATA2"/>
					<button 
						id="SkyFill"
						image="i_fill_sky"
						size="normal"
						supertip="Sky fill color"
						onAction="Format_onAction" 
						tag="Fill:DATA3"/>
					<button 
						id="PineFill"
						image="i_fill_pine"
						size="normal"
						supertip="Pine fill color"
						onAction="Format_onAction" 
						tag="Fill:DATA4"/>
					<button 
						id="GoldFill"
						image="i_fill_gold"
						size="normal"
						supertip="Gold fill color"
						onAction="Format_onAction" 
						tag="Fill:DATA5"/>
					<button 
						id="RustFill"
						image="i_fill_rust"
						size="normal"
						supertip="Rust fill color"
						onAction="Format_onAction" 
						tag="Fill:DATA6"/>
					<button 
						id="LavenderFill"
						image="i_fill_lavender"
						size="normal"
						supertip="Lavender fill color"
						onAction="Format_onAction" 
						tag="Fill:DATA7"/>
					<button 
						id="SteelFill"
						image="i_fill_steel"
						size="normal"
						supertip="Steel fill color"
						onAction="Format_onAction" 
						tag="Fill:NEUTRAL2"/>
					<button 
						id="WhiteFill"
						image="i_fill_white"
						size="normal"
						supertip="White fill color"
						onAction="Format_onAction" 
						tag="Fill:NEUTRAL4"/>
				</group >
                <group
					id="ColorRamps"
					label="Colour Ramps">
					<button
						id="OceanRamp"
						image="i_ramp_ocean"
						size="normal"
						supertip="Apply Ocean colour ramp to chart series."
						onAction="ApplyRamp_onAction"
						tag="A"/>
					<button
						id="CoralRamp"
						image="i_ramp_coral"
						size="normal"
						supertip="Apply Coral colour ramp to chart series."
						onAction="ApplyRamp_onAction"
						tag="B"/>
					<button
						id="SkyRamp"
						image="i_ramp_sky"
						size="normal"
						supertip="Apply Sky colour ramp to chart series."
						onAction="ApplyRamp_onAction"
						tag="C"/>
					<button
						id="PineRamp"
						image="i_ramp_pine"
						size="normal"
						supertip="Apply Pine colour ramp to chart series."
						onAction="ApplyRamp_onAction"
						tag="D"/>
					<button
						id="GoldRamp"
						image="i_ramp_gold"
						size="normal"
						supertip="Apply Gold colour ramp to chart series."
						onAction="ApplyRamp_onAction"
						tag="E"/>
					<button
						id="RustRamp"
						image="i_ramp_rust"
						size="normal"
						supertip="Apply Rust colour ramp to chart series."
						onAction="ApplyRamp_onAction"
						tag="F"/>
					<button
						id="LavenderRamp"
						image="i_ramp_lavender"
						size="normal"
						supertip="Apply Lavender colour ramp to chart series."
						onAction="ApplyRamp_onAction"
						tag="G"/>
					</group >
				<group
					id="DivergingRamps"
					label="Diverging Ramps">
					<button
						id="DivRamp_OceanPine"
						image="i_div_ocean_pine"
						size="normal"
						supertip="Diverging ramp: Ocean (dark to light) — Pine (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="A|D"/>
					<button
						id="DivRamp_OceanGold"
						image="i_div_ocean_gold"
						size="normal"
						supertip="Diverging ramp: Ocean (dark to light) — Gold (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="A|E"/>
					<button
						id="DivRamp_OceanRust"
						image="i_div_ocean_rust"
						size="normal"
						supertip="Diverging ramp: Ocean (dark to light) — Rust (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="A|F"/>
					<button
						id="DivRamp_OceanLavender"
						image="i_div_ocean_lavender"
						size="normal"
						supertip="Diverging ramp: Ocean (dark to light) — Lavender (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="A|G"/>
					<button
						id="DivRamp_SkyCoral"
						image="i_div_coral_sky"
						size="normal"
						supertip="Diverging ramp: Sky (dark to light) — Coral (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="C|B"/>
					<button
						id="DivRamp_PineRust"
						image="i_div_pine_rust"
						size="normal"
						supertip="Diverging ramp: Pine (dark to light) — Rust (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="D|F"/>
					<button
						id="DivRamp_PineLavender"
						image="i_div_pine_lavender"
						size="normal"
						supertip="Diverging ramp: Pine (dark to light) — Lavender (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="D|G"/>
					<button
						id="DivRamp_PineGold"
						image="i_div_pine_gold"
						size="normal"
						supertip="Diverging ramp: Pine (dark to light) — Gold (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="D|E"/>
					<button
						id="DivRamp_GoldRust"
						image="i_div_gold_rust"
						size="normal"
						supertip="Diverging ramp: Gold (dark to light) — Rust (light to dark)."
						onAction="ApplyDivergingRamp_onAction"
						tag="E|F"/>
				</group>
                <group 
                    id="FillActions"
                    label="Fill Actions">
					<button
						id="TogglePaletteOrder"
						image="i_menu_order"
						size="large"
						label="Toggle Palette Order"
						supertip="Switch the series colour order between Contrasting and Complementary."
						onAction="TogglePaletteOrder_onAction"/>
					<button
						id="InvertRampButton"
						image="i_menu_invert"
						label="Invert Ramp"
						size="large"
						supertip="Reverse the fill colour order across all chart series."
						onAction="InvertRamp_onAction"/>
					<button
						id="StartWithGrayButton"
						image="i_menu_grey"
						label="Reset to Grey"
						size="large"
						supertip="Reset all chartobjects to grey."
						onAction="StartWithGrayButton_onAction"/>
				</group>
				<group id="Customisation" label="Customisation">
					<button
						id="LabelLastPointButton"
						image="i_menu_labels"
						label="Label Last Point"
						size="large"
						supertip="Add series names to the last point on the graph."
						onAction="LabelLastPointButton_onAction"/>
					<button
						id="ToggleDataLabelsButton"
						image="i_menu_labels"
						label="Toggle Data Labels"
						size="large"
						supertip="Cycle data labels: none → outside end → inside centre. Applies to selected series or all series."
						onAction="ToggleDataLabelsButton_onAction"/>
					<button
						id="ToggleGridlinesButton"
						image="i_menu_gridlines"
						label="Toggle Gridlines"
						size="large"
						supertip="Cycle gridlines on the selected chart: none → horizontal → vertical → both."
						onAction="ToggleGridlinesButton_onAction"/>
					<button
						id="ToggleAxisButton"
						image="i_menu_axislines"
						label="Toggle Axis Lines"
						size="large"
						supertip="Cycle axis lines on the selected chart: none → x-axis → y-axis → both."
						onAction="ToggleAxesButton_onAction"/>
					<button
						id="RemoveLegendResizeButton"
						image="i_menu_none"
						label="Remove Legend"
						size="large"
						supertip="Remove the chart legend and resize the plot area to standard web dimensions."
						onAction="RemoveLegendResizeButton_onAction"/>
					<button
						id="ToggleChartVariantButton"
						image="i_menu_none"
						label="Toggle Variant"
						size="large"
						supertip="Toggle between chart type variants: stacked ↔ 100% stacked, pie ↔ donut, line ↔ line with markers."
						onAction="ToggleChartVariantButton_onAction"/>
				</group>
				<group id="ChartExportButton" label="Export">
					<button
						id="ChartExport"
						image="i_menu_export"
						label="Chart Export"
						size="large"
						supertip="Export chart as PNG, GIF, JPG, BMP, SVG, or PDF. Note that this will *not* warn you to overwrite an existing file."
						onAction="ChartExport_onAction"/>
				</group>
			</tab>
		</tabs >
	</ribbon >
</customUI >
