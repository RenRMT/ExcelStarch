' Converts Base64 string into a file on disk.
Public Function Base64ToFile(base64 As String, outputPath As String) As Boolean
    On Error GoTo Fail

    Dim arr() As Byte
    arr = Base64Decode(base64)

    Dim f As Integer
    f = FreeFile
    Open outputPath For Binary As #f
    Put #f, , arr
    Close #f

    Base64ToFile = True
    Exit Function

Fail:
    Base64ToFile = False
End Function


' Core Base64 decoding (binary safe)
Public Function Base64Decode(base64 As String) As Byte()
    Dim XML As Object, Node As Object

    Set XML = CreateObject("MSXML2.DOMDocument")
    Set Node = XML.createElement("b64")

    Node.DataType = "bin.base64"
    Node.Text = base64

    Base64Decode = Node.nodeTypedValue
End Function

